riceFeed != address(0), \"Invalid feed address\");\n        priceFeed = AggregatorV3Interface(_priceFeed);\n    }\n    \n    function getPrice() external view returns (uint256 price, uint8 decimals) {\n        (\n            uint80 roundId,\n            int256 answer,\n            ,\n            uint256 updatedAt,\n            uint80", "with_skill_answer": "# 在 Solidity 中调用 Chainlink ETH/USD 价格预言机\n\n## 完整实现代码\n\n```solidity\n// SPDX-License-Identifier: MIT\npragma solidity ^0.8.0;\n\nimport \"@chainlink/contracts/src/v0.8/interfaces/AggregatorV3Interface.sol\";\n\ncontract ETHPriceConsumer {\n    AggregatorV3Interface internal priceFeed;\n    \n    // ETH/USD 主网地址\n    address constant ETH_USD_FEED = 0x5f4eC3Df9cbd43714FE2740f5E3616155c5b8419;\n    \n    constructor() {\n        priceFeed = AggregatorV3Interface(ETH_USD_FEED);\n    }\n    \n    /// @notice 获取 ETH/USD 最新价格\n    /// @return price 价格（已转换为 18 位精度）\n    function getETHPrice() public view returns (uint256) {\n        (\n            uint80 roundId,\n            int256 price,\n            uint256 startedAt,\n            uint256 updatedAt,\n            uint80 answeredInRound\n        ) = priceFeed.latestRoundData();\n        \n        // ✅ 安全检查\n        require(price > 0,            \"价格不能为负或零\");\n        require(updatedAt > 0,        \"数据尚未更新\");\n        require(answeredInRound >= roundId, \"数据已过期\");\n        require(\n            block.timestamp - updatedAt <= 1 hours, \n            \"价格数据超过1小时未更新\"\n        );\n        \n        // 将 8 位精度转换为 18 位精度\n        return uint256(price) * 1e10;\n    }\n    \n    /// @notice 将 ETH 数量换算为 USD 价值\n    /// @param ethAmount ETH 数量（18位精度）\n    function ethToUSD(uint256 ethAmount) public view returns (uint256) {\n        uint256 ethPrice = getETHPrice(); // 18位精度\n        return (ethAmount * ethPrice) / 1e18;\n    }\n}\n```\n\n---\n\n## 关键注意事项\n\n### ⚠️ 1. 精度处理（最易出错）\n\n```\nlatestRoundData() 返回的 price 是 8 位小数\n例如：200000000000 = $2000.00000000\n\n换算公式：\n实际价格 = price