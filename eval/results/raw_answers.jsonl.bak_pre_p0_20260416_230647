)\n}\n```\n\n---\n\n## 带插件的铸造\n\n```typescript\nimport { create, ruleSet } from '@metaplex-foundation/mpl-core'\n\nawait create(", "with_skill_answer": "## 在 Metaplex Core 中铸造 NFT 到集合\n\n### 安装依赖\n\n```bash\nnpm install @metaplex-foundation/mpl-core @metaplex-foundation/umi\n```\n\n### 完整示例\n\n```typescript\nimport { createUmi } from '@metaplex-foundation/umi-bundle-defaults'\nimport { mplCore, createV1, fetchCollection } from '@metaplex-foundation/mpl-core'\nimport { generateSigner, keypairIdentity } from '@metaplex-foundation/umi'\n\n// 1. 初始化 Umi\nconst umi = createUmi('https://api.devnet.solana.com')\n  .use(mplCore())\n  .use(keypairIdentity(yourKeypair))\n\n// 2. 先创建集合（如尚未创建）\nconst collectionSigner = generateSigner(umi)\n\nawait createCollectionV1(umi, {\n  collection: collectionSigner,\n  name: 'My Collection',\n  uri: 'https://example.com/collection.json',\n}).sendAndConfirm(umi)\n\n// 3. 铸造 NFT 资产到集合\nconst assetSigner = generateSigner(umi)\n\nawait createV1(umi, {\n  asset: assetSigner,\n  collection: collectionSigner.publicKey, // 指定所属集合\n  name: 'My NFT #1',\n  uri: 'https://example.com/nft-1.json',\n  owner: umi.identity.publicKey,           // 可选，默认为当前身份\n}).sendAndConfirm(umi)\n\nconsole.log('NFT 已铸造:', assetSigner.publicKey.toString())\n```\n\n### 关键参数说明\n\n| 参数 | 说明 |\n|------|------|\n| `asset` | 新 NFT 的 Signer（密钥对） |\n| `collection` | 目标集合的公钥 |\n| `name` | NFT 名称 |\n| `uri` | 指向链下元数据的 JSON URI |\n| `owner` | NFT 初始持有者（可选） |\n\n### 元数据 JSON 格式参考\n\n```json\n{\n  \"name\": \"My NFT #1\",\n  \"description\": \"描述\",\n  \"image\": \"https://example.com/image.png\",\n  \"attributes\": [\n    { \"trait_type\": \"Background\", \"value\": \"Blue\" }\n  ]\n}\n```\n\n### 注意事项\n\n- **Metaplex Core** 是新一代标准，资产结构比 Token Metadata 更轻量\n- 集合必须提前创建，铸造时引用其 `publicKey`\n- `uri` 建议托管在 **Arweave** 或 **IPFS** 以保证去中心化存储", "skill_found": true, "question_id": "Q1030", "category": "SOL", "skill_id": "solana/metaplex-nft", "ground_truth": "NFT assets are minted into collec