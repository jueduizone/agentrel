``\n\n### 方式二：Jito Tip（更激进）\n\n向 Jito 的 tip 账户转账 SOL：\n\n```javascript\nimport {\n  address,\n  createTransactionMessage,\n  appendTransactionMessageInstructions,\n  pipe,\n} from \"@solana/web3.js\";\nimport { getTransferSolInstruction } from \"@solana-program/system\";\n\n// Jito tip 账户（8个之一随机选择）\nconst JITO_TIP_ACCOUNTS = [\n  \"96gYZGLnJYVFmbjzopPSU6QiEV5fGqZNyN9nmNhvrZU5\",\n  \"HFqU5x63VTqvQss8hp11i4wVV8bD44PvwucfZ2bU7gRe\",\n  // ... 其他账户\n];\n\nconst tipAccount = address(\n  JITO_TIP_ACCOUNTS[Math.floor(Math.random() * JITO_TIP_ACCOUNTS.length)]\n);\n\nconst tipInstruction = getTransferSolInstruction({\n  source: signer,\n  destination: tipAccount,\n  amount: 1_000_000n, // 0.001 SOL (lamports)\n});\n```\n\n### 发送到 Jito RPC\n\n```javascript\nimport { createSolanaRpc } from \"@solana/web3.js\";\n\n// 使用 Jito 的 RPC 端点而非标准端点\nconst rpc = createSolanaRpc(\"https://mainnet.block-engine.jito.wtf/api/v1/transactions\");\n```\n\n---\n\n## 建议策略\n\n| 场景 | 策略 |\n|------|------|\n| 普通交易 | Priority Fee 即可 |\n| 高竞争（NFT mint、套利） | Priority Fee + Jito Tip |\n| 需要原子性多笔交易 | Jito Bundle |\n\n**Tip 金额参考**：0", "skill_found": true, "question_id": "SOL-Q36", "category": "SOL", "skill_id": "solana/web3js-v2", "ground_truth": "Jito 是 Solana 的 MEV 基础设施，提供 block engine 和 bundle 服务。提高优先级方式：1. 在交易末尾添加 tip 转账给 Jito tip 账户（当前约 0.001 SOL）；2. 通过 Jito RPC 发送 bundle（多交易原子执行）。比纯 priority fee 更可靠，适合套利/清算场景。", "question_text": "Solana 上的 Jito 是什么？如何通过 Jito 提高交易优先级？", "provider": "anthropic/claude-sonnet-4-6"}
{"bare_answer": "## Solana 程序日志输出\n\n### 程序中输出日志\n\n```rust\nuse solana_program::msg;\n\n// 基本字符串日志\nmsg!(\"Hello from Solana program!\");\n\n// 格式化日志（类似 println!）\nmsg!(\"Value: {}\", some_value);\nmsg!(\"Account: {:?}\", account_info.key);\n\n// 数值日志（更省 CU）\nsolana_program::log::sol_log_64(val1, val2, val3, val4, val5);\n```\n\n---\n\n### 测试中查看日志\n\n#### 方式一：`solana-program-test`（推荐）\n\n```rust\n#[cfg(test)]\nmod tests {\n    use solana_program_test::*;\n    use solana_sdk::instruction::Instruction;\n\n    #[tokio::test]\n    async fn test_with_logs() {\n        // 启用日志（设置环境变量）\n        solana_logger::setup_with_default(\"solana_runtime::message=debug\");\n\n        let program_id = Pubkey::new_unique();\n        let mut program_test = ProgramTest::new(\n            \"my_program\",\n            program_id,\n            processor!(process_instruction),\n        );\n\n        let (mut banks_client, payer, recent_blockhash) = \n            program_test.start().await;\n\n        // 发送交易\n        let tx = Transaction::new_signed_with_payer(/* ... */);\n        \n        // 执行并获取元数据\n        let result = banks_client\n            .process_transaction_with_metadata(tx)\n            .await\n            .unwrap();\n\n        // 查看日志\n        for log in &result.metadata.unwrap().log_messages {\n            println!(\"{}\", log);\n        }\n    }\n}\n```\n\n#### 方式二：直接运行测试时显示日志\n\n```bash\n# 运行测试时显示 stdout\ncargo test -- --nocapture\n\n# 同时设置日志级别\nRUST_LOG=debug cargo test -- --nocapture\n\n# 只显示程序日志\nRUST_LOG=solana_runtime::message=debug cargo test -- --nocapture\n```\n\n#### 方式三：Anchor 框架\n\n```rust\n// 程序中\nuse anchor_lang::prelude::*;\n\n#[program]\nmod my_program {\n    pub fn initialize(ctx: Context<Initialize>) -> Result<()> {\n        msg!(\"Instruction: Initialize\");\n        msg!(\"User: {}\", ctx.accounts.user.key());\n        Ok(())\n    }\n}\n```\n\n```typescript\n// Anchor 测试（TypeScript）\nit(\"logs test\", async () => {\n    const tx = await program.methods\n        .initialize()\n        .rpc();\n\n    // 获取交易日志\n    const txDetails = await provider.connection.getTransaction(tx, {\n        commitment: \"confirmed\",\n    });\n\n    console.log(\"Logs:\", txDetails?.meta?.logMessages);\n});\n```\n\n---\n\n### 日志输出格式\n\n```\nProgram <program_id> invoke [1]\nProgram log: Hello from", "with_skill_answer": "## Solana 程序日志输出\n\n### 程序中输出日志\n\n```rust\nuse anchor_lang::prelude::*;\n\n#[program]\npub mod my_program {\n    use super::*;\n    \n    pub fn initialize(ctx: Context<Initialize>, value: u64) -> Result<()> {\n        // 基本日志\n        msg!(\"Program initialized!\");\n        \n        // 格式化日志\n        msg!(\"Value: {}\", value);\n        msg!(\"Authority: {}\", ctx.accounts.authority.key());\n        \n        Ok(())\n    }\n}\n```\n\n### 测试中查看日志\n\n**TypeScript 测试：**\n```typescript\nit(\"should initialize\", async () => {\n    const tx = await program.methods\n        .initialize(new BN(42))\n        .accounts({ /* ... */ })\n        .rpc();\n    \n    // 获取交易日志\n    const txDetails = await provider.connection.getTransaction(tx, {\n        commitment: \"confirmed\",\n    });\n    \n    console.log(\"Logs:\", txDetails?.meta?.logMessages);\n});\n```\n\n**启动本地测试节点时显示日志：**\n```bash\n# 启动时开启详细日志\nsolana-test-validator --log\n\n# 运行测试并显示日志\nanchor test -- --nocapture\n```\n\n**`Anchor.toml` 配置：**\n```toml\n[scripts]\ntest = \"yarn run ts-mocha -p ./tsconfig.json -t 1000000 tests/**/*.ts\"\n```\n\n### 关键点\n\n| 方式 | 说明 |\n|------|------|\n| `msg!()` | 程序内唯一推荐的日志宏 |\n| `logMessages` | 交易回执中包含所有日志 |\n| `--log` | 验证节点实时打印日志 |\n\n> ⚠️ `msg!()` 会消耗 **compute units**，生产环境注意控制日志量。", "skill_found": true, "question_id": "SOL-Q38", "category": "SOL", "skill_id": "protocols/solana-anchor-guide", "ground_truth": "程序内：`msg!(\"value: {}\", x)` — 类似 Rust println!，但输出到交易 logs。`sol_log_compute_units()` 打印剩余 compute units。测试中：`context.banks_client` 执行后查看 `transaction_result.metadata().logs`；本地验证器 `solana logs` 命令实时查看；Anchor 测试框架自动打印程序 logs。", "question_text": "Solana 程序如何输出日志？在测试中如何查看日志？", "provider": "anthropic/claude-sonnet-4-6"}
{"bare_answer": "# Solana Compute Units 详解\n\n## 默认限制\n\n| 级别 | 限制 |\n|------|------|\n| 单条指令默认 | 200,000 CU |\n| 单笔交易最大 | 1,400,000 CU |\n| 单个区块最大 | 48,000,000 CU |\n\n---\n\n## 设置自定义 Compute Budget\n\n### 1. 安装依赖\n\n```bash\nnpm install @solana/web3.js @solana/spl-token\n```\n\n### 2. 基本用法\n\n```typescript\nimport {\n  Transaction,\n  ComputeBudgetProgram,\n  sendAndConfirmTransaction,\n  Connection,\n  Keypair,\n} from \"@solana/web3.js\";\n\nconst connection = new Connection(\"https://api.mainnet-beta.solana.com\");\n\n// ① 设置 Compute Unit 限制\nconst setComputeUnitLimit = ComputeBudgetProgram.setComputeUnitLimit({\n  units: 400_000, // 自定义 CU 上限\n});\n\n// ② 设置优先费用 (Priority Fee)\nconst setComputeUnitPrice = ComputeBudgetProgram.setComputeUnitPrice({\n  microLamports: 1_000, // 每个 CU 的价格（微 lamports）\n});\n\nconst transaction = new Transaction()\n  .add(setComputeUnitLimit)   // 必须放在最前面\n  .add(setComputeUnitPrice)   // 必须放在最前面\n  .add(/* 你的业务指令 */);\n```\n\n### 3. 完整示例\n\n```typescript\nimport {\n  Connection,\n  Keypair,\n  Transaction,\n  ComputeBudgetProgram,\n  SystemProgram,\n  PublicKey,\n  LAMPORTS_PER_SOL,\n  sendAndConfirmTransaction,\n} from \"@solana/web3.js\";\n\nasync function sendWithComputeBudget() {\n  const connection = new Connection(\n    \"https://api.devnet.solana.com\",\n    \"confirmed\"\n  );\n  \n  const payer = Keypair.generate();\n  const recipient = Keypair.generate();\n\n  // 1. 模拟交易预估 CU 消耗\n  const simulateTx = new Transaction().add(\n    SystemProgram.transfer({\n      fromPubkey: payer.publicKey,\n      toPubkey: recipient.publicKey,\n      lamports: 0.01 * LAMPORTS_PER_SOL,\n    })\n  );\n  \n  const simulation = await connection.simulateTransaction(simulateTx);\n  const estimatedCU = simulation.value.unitsConsumed ?? 200_000;\n  console.log(`预估消耗 CU: ${estimatedCU}`);\n\n  // 2. 设置 CU 限制（预估值 * 1.2 作为缓冲）\n  const cuLimit = Math.ceil(estimatedCU * 1.2);", "with_skill_answer": "## Solana Compute Units 说明\n\n### 默认限制\n\n每笔 Solana 交易的 compute units (CU) 限制：\n\n- **单条指令默认上限**：200,000 CU\n- **整笔交易最大上限**：1,400,000 CU\n\n---\n\n## 使用 web3.js v2 设置自定义 Compute Budget\n\n### 安装依赖\n\n```bash\nnpm install @solana/web3.js@2 @solana-program/compute-budget\n```\n\n### 完整示例\n\n```typescript\nimport {\n  createSolanaRpc,\n  createSolanaRpcSubscriptions,\n  createTransactionMessage,\n  setTransactionMessageFeePayer,\n  setTransactionMessageLifetimeUsingBlockhash,\n  appendTransactionMessageInstructions,\n  signTransactionMessageWithSigners,\n  sendAndConfirmTransactionFactory,\n  pipe,\n} from \"@solana/web3.js\";\n\nimport {\n  getSetComputeUnitLimitInstruction,\n  getSetComputeUnitPriceInstruction,\n} from \"@solana-program/compute-budget\";\n\nconst rpc = createSolanaRpc(\"https://api.mainnet-beta.solana.com\");\nconst rpcSubscriptions = createSolanaRpcSubscriptions(\n  \"wss://api.mainnet-beta.solana.com\"\n);\n\nconst sendAndConfirm = sendAndConfirmTransactionFactory({\n  rpc,\n  rpcSubscriptions,\n});\n\nconst { value: latestBlockhash } = await rpc.getLatestBlockhash().send();\n\nconst transactionMessage = pipe(\n  createTransactionMessage({ version: 0 }),\n  (tx) => setTransactionMessageFeePayer(feePayer.address, tx),\n  (tx) => setTransactionMessageLifetimeUsingBlockhash(latestBlockhash, tx),\n  (tx) =>\n    appendTransactionMessageInstructions(\n      [\n        // 1️⃣ 设置 Compute Unit 上限\n        getSetComputeUnitLimitInstruction({\n          units: 50_000, // 根据实际需求设置，越精确越好\n        }),\n\n        // 2️⃣ 设置优先费用（micro-lamports per CU）\n        getSetComputeUnitPriceInstruction({\n          microLamports: 1_000, // 提高优先级\n        }),\n\n        // 3️⃣ 你的业务指令\n        yourInstruction,\n      ],\n      tx\n    )\n);\n\nconst signedTx = await signTransactionMessageWithSigners(transactionMessage);\nawait sendAndConfirm(signedTx, { commitment: \"confirmed\" });\n```\n\n---\n\n## 最佳实践\n\n### 模拟交易获取精确 CU 用量\n\n```typescript\n// 先模拟，再设置精确的 CU limit\nconst simulationResult = await rpc\n  .simulateTransaction(transactionMessage, {\n    sigVerify: false,\n    commitment: \"confirmed\",\n  })\n  .send();\n\nconst estim", "skill_found": true, "question_id": "SOL-Q39", "category": "SOL", "skill_id": "solana/web3js-v2", "ground_truth": "默认限制：每条指令 200,000 CU，单交易最多 1,400,000 CU。自定义：添加 `ComputeBudgetProgram.setComputeUnitLimit({ units: 300000 })` 指令提高上限；添加 `setComputeUnitPrice({ microLamports: 1000 })` 设置优先费。两条指令加在交易最前面。", "question_text": "Solana 交易的 compute units 限制是多少？如何设置自定义 compute budget？", "provider": "anthropic/claude-sonnet-4-6"}
{"bare_answer": "# Anchor 中的 CPI（跨程序调用）\n\n## 基本 CPI 调用\n\n### 普通 CPI 调用\n\n```rust\nuse anchor_lang::prelude::*;\nuse anchor_spl::token::{self, Token, Transfer};\n\n#[program]\npub mod my_program {\n    use super::*;\n\n    pub fn transfer_tokens(ctx: Context<TransferTokens>, amount: u64) -> Result<()> {\n        // 方式1: 使用 CpiContext::new\n        let cpi_accounts = Transfer {\n            from: ctx.accounts.from.to_account_info(),\n            to: ctx.accounts.to.to_account_info(),\n            authority: ctx.accounts.authority.to_account_info(),\n        };\n        \n        let cpi_program = ctx.accounts.token_program.to_account_info();\n        let cpi_ctx = CpiContext::new(cpi_program, cpi_accounts);\n        \n        token::transfer(cpi_ctx, amount)?;\n        Ok(())\n    }\n}\n\n#[derive(Accounts)]\npub struct TransferTokens<'info> {\n    #[account(mut)]\n    pub from: Account<'info, TokenAccount>,\n    #[account(mut)]\n    pub to: Account<'info, TokenAccount>,\n    pub authority: Signer<'info>,\n    pub token_program: Program<'info, Token>,\n}\n```\n\n---\n\n## PDA 作为签名者的 CPI\n\n### 核心概念\n\n```\n普通签名: 私钥签名\nPDA 签名: 程序通过 seeds + bump 证明\"我拥有这个 PDA\"\n```\n\n### 完整示例\n\n```rust\nuse anchor_lang::prelude::*;\nuse anchor_spl::token::{self, Token, TokenAccount, Transfer};\n\n#[program]\npub mod my_program {\n    use super::*;\n\n    pub fn transfer_with_pda(ctx: Context<TransferWithPda>, amount: u64) -> Result<()> {\n        // PDA seeds 必须与派生时完全一致\n        let seeds = &[\n            b\"vault\",                              // 静态 seed\n            ctx.accounts.user.key.as_ref(),        // 动态 seed\n            &[ctx.accounts.vault.bump],            // bump seed\n        ];\n        let signer_seeds = &[&seeds[..]];          // 注意双层引用\n        \n        let cpi_accounts = Transfer {\n            from: ctx.accounts.vault_token_account.to_account_info(),\n            to: ctx.accounts.user_token_account.to_account_info(),\n            authority: ctx.accounts.vault.to_account_info(), // PDA 作为 authority\n        };\n        \n        let cpi_program = ctx.accounts.token_program.to_account_info();\n        \n        // 使用 CpiContext::new_with_signer 传入 signer seeds\n        let cpi_ctx = CpiContext::new_with_signer(\n            cpi_program,\n            cpi_accounts,\n            signer_seeds,  // 关键：让程", "with_skill_answer": "# Anchor 中的 CPI（跨程序调用）详解\n\n## 一、基础 CPI 概念\n\nCPI 允许一个程序调用另一个程序的指令，调用深度最多 **4 层**。\n\n---\n\n## 二、标准 CPI 调用\n\n### 2.1 调用系统程序转账\n\n```rust\nuse anchor_lang::prelude::*;\nuse anchor_lang::system_program;\n\n#[program]\npub mod cpi_demo {\n    use super::*;\n\n    pub fn transfer_sol(ctx: Context<TransferSol>, amount: u64) -> Result<()> {\n        // 方式一：使用 Anchor 封装的 CPI 模块（推荐）\n        let cpi_context = CpiContext::new(\n            ctx.accounts.system_program.to_account_info(),\n            system_program::Transfer {\n                from: ctx.accounts.sender.to_account_info(),\n                to:   ctx.accounts.recipient.to_account_info(),\n            },\n        );\n        system_program::transfer(cpi_context, amount)?;\n        Ok(())\n    }\n}\n\n#[derive(Accounts)]\npub struct TransferSol<'info> {\n    #[account(mut)]\n    pub sender: Signer<'info>,\n    \n    #[account(mut)]\n    pub recipient: SystemAccount<'info>,\n    \n    pub system_program: Program<'info, System>,\n}\n```\n\n### 2.2 调用外部 Anchor 程序\n\n```rust\n// 引入目标程序（通过 declare_program! 或依赖其 crate）\nuse other_program::cpi::accounts::DoSomething;\nuse other_program::program::OtherProgram;\n\npub fn call_other_program(ctx: Context<CallOther>, data: u64) -> Result<()> {\n    let cpi_accounts = DoSomething {\n        user:        ctx.accounts.user.to_account_info(),\n        data_account: ctx.accounts.data_account.to_account_info(),\n    };\n\n    let cpi_ctx = CpiContext::new(\n        ctx.accounts.other_program.to_account_info(),\n        cpi_accounts,\n    );\n\n    // 调用目标程序的指令\n    other_program::cpi::do_something(cpi_ctx, data)?;\n    Ok(())\n}\n```\n\n---\n\n## 三、PDA 作为签名者（核心重点）\n\n### 3.1 为什么 PDA 能签名？\n\n```\n普通账户：私钥签名\nPDA 账户：程序通过提供 seeds + bump 来\"签名\"\n         ——链上验证 derive_program_address(seeds) == PDA 地址\n```\n\n### 3.2 PDA 签名的完整示例\n\n```rust\nuse anchor_lang::prelude::*;\nuse anchor_spl::token::{self, Token, TokenAccount, Transfer};\n\n#[program]\npub mod pda_signer_demo {\n    use super::*;\n\n    pub fn vault_", "skill_found": true, "question_id": "SOL-Q37", "category": "SOL", "skill_id": "protocols/solana-anchor-guide", "ground_truth": "`CpiContext::new(ctx.accounts.token_program.to_account_info(), TransferAccounts { ... })` + `transfer(cpi_ctx, amount)`。PDA 签名：`CpiContext::new_with_signer(program, accounts, &[&[seeds..., &[bump]]])` — seeds 加 bump 组成 signer_seeds，`invoke_signed` 会验证 PDA 地址。", "question_text": "Anchor 中如何进行 CPI（跨程序调用）？PDA 作为签名者时如何处理？", "provider": "anthropic/claude-sonnet-4-6"}
{"bare_answer": "# SPL Token-2022 核心扩展\n\n## 转账相关扩展\n\n### 1. Transfer Fee（转账手续费）\n```rust\n// 每次转账自动扣取手续费，存入指定账户\nTransferFeeConfig {\n    transfer_fee_config_authority: Option<Pubkey>,\n    withdraw_withheld_authority: Option<Pubkey>,\n    withheld_amount: u64,\n    older_transfer_fee: TransferFee,\n    newer_transfer_fee: TransferFee,\n}\n```\n\n### 2. Transfer Hook（转账钩子）\n- 转账时**强制调用**指定的自定义程序\n- 可实现合规检查、黑名单、自定义逻辑\n```\nTransfer → Token-2022 → Hook Program (CPI) → 继续/回滚\n```\n\n---\n\n## 铸造控制扩展\n\n| 扩展 | 功能 |\n|------|------|\n| **Mint Close Authority** | 允许关闭供应量为0的Mint账户 |\n| **Interest-Bearing** | 链上计息，余额随时间增长（展示用） |\n| **Non-Transferable** | 灵魂绑定Token，禁止转账 |\n| **Permanent Delegate** | 永久委托，可无限转移/销毁任意账户余额 |\n\n---\n\n## 元数据扩展\n\n### Metadata Pointer + Token Metadata\n```\n无需依赖 Metaplex，直接在 Mint 账户存储元数据\nMint Account {\n    // 标准字段...\n    MetadataPointer → 指向元数据地址（可以是自身）\n    TokenMetadata {\n        name, symbol, uri,\n        additional_metadata: Vec<(String, String)> // 自定义KV\n    }\n}\n```\n\n---\n\n## 账户安全扩展\n\n### Confidential Transfer（机密转账）\n```\n基于 ZK Proof (ElGamal加密)\n链上只存加密余额，转账金额对外不可见\n需要先 ApplyPendingBalance → 再 Transfer\n```\n\n### CPI Guard\n- 限制在 CPI 调用中的危险操作\n- 防止恶意程序在 CPI 中转移用户资产\n\n---\n\n## Group/Member 扩展（较新）\n\n```\nToken Group  →  定义集合\nToken Member →  加入某个 Group\n类似 NFT Collection，但原生支持\n```\n\n---\n\n## 账户层面扩展\n\n| 扩展 | 说明 |\n|------|------|\n| **Memo Required** | 转入必须附带 Memo |\n| **Immutable Owner** | Token Account 所有者不可变 |\n| **Default Account State** | 新账户默认冻结状态 |\n\n---\n\n## 架构对比\n\n```\n旧版 Token Program\n└── 固定账构，功能单一", "with_skill_answer": "## SPL Token-2022 核心扩展\n\n> ⚠️ 提示：您提供的文档中未涵盖 Token-2022 的详细内容，以下基于我的训练知识回答。\n\n### 主要扩展分类\n\n**Transfer 相关**\n- **Transfer Fee** — 转账时自动扣取手续费（类似税代币机制）\n- **Transfer Hook** — 每次转账触发自定义程序逻辑（EVM 中无直接对应）\n\n**Mint 相关**\n- **Mint Close Authority** — 允许关闭空的 Mint 账户并回收租金\n- **Confidential Transfers** — 基于 ZK Proof 隐藏转账金额\n- **Non-transferable Tokens** — 灵魂绑定代币（SBT）\n- **Permanent Delegate** — 永久委托，可无限操控任意持有者余额\n\n**Interest & Metadata**\n- **Interest-Bearing Tokens** — 链上计息，余额随时间增长（显示值）\n- **Token Metadata** — 原生内嵌 metadata，无需额外 Metaplex 账户\n- **Token Group / Member** — 原生支持 NFT Collection 分组\n\n**账户管理**\n- **Immutable Owner** — Token Account 所有者不可更改\n- **Default Account State** — 新建账户默认冻结，需 KYC 后解冻\n- **Required Memo** — 转账必须附带备注（合规场景）\n- **CPI Guard** — 防止恶意 CPI 调用操控用户账户\n\n### 与旧版核心差异\n\n| 维度 | Token Program | Token-2022 |\n|------|--------------|------------|\n| Program ID | `TokenkegQfe...` | `TokenzQdBNb...` |\n| Metadata | 依赖 Metaplex | 原生支持 |\n| 合规能力 | 无 | 黑名单/冻结/Memo |\n| 隐私 | 无 | ZK 隐私转账 |", "skill_found": true, "question_id": "SOL-Q40", "category": "SOL", "skill_id": "solana/program-model", "ground_truth": "主要扩展：1. TransferFee（转账自动扣费）；2. ConfidentialTransfer（基于 ElGamal 加密的隐私转账）；3. InterestBearingMint（原生利息）；4. NonTransferable（灵魂绑定代币）；5. PermanentDelegate（永久授权）；6. TransferHook（转账时调用自定义程序）。", "question_text": "SPL Token-2022 相比旧版 Token Program 新增了哪些核心扩展？", "provider": "anthropic/claude-sonnet-4-6"}
{"bare_answer": "# Solana Rent 机制详解\n\n## 什么是 Rent？\n\nSolana 网络需要验证节点将所有账户数据保存在内存中，为了防止状态膨胀，引入了 **租金（Rent）** 机制——账户需要为占用的存储空间付费。\n\n---\n\n## 两种模式\n\n### 1. 按期付租（已废弃）\n- 账户余额不足时，定期扣除租金\n- 余额归零后账户被清除\n\n### 2. 免租豁免（Rent-exempt）✅ 推荐/强制\n- 账户保持**最低余额**，永久存在，不再扣租\n- 目前 Solana **强制要求**所有新账户必须达到免租状态\n\n---\n\n## 免租金额计算公式\n\n```\n免租最低余额 = 账户数据大小(bytes) × 每字节年租金 × 2年 + 基础费用\n```\n\n**官方简化公式：**\n```\nlamports = (DATA_SIZE + 128) × 6960 × 2\n```\n\n| 参数 | 说明 |\n|------|------|\n| `DATA_SIZE` | 账户 data 字段的字节数 |\n| `+ 128` | 账户元数据固定开销（pubkey、owner等） |\n| `6960` | 每字节每年租金（lamports） |\n| `× 2` | 2年豁免系数（历史设计） |\n\n---\n\n## 实际计算示例\n\n### 空账户（只存 SOL，data = 0）\n```\n(0 + 128) × 6960 × 2 = 1,781,760 lamports ≈ 0.00178 SOL\n```\n\n### Token Account（data = 165 bytes）\n```\n(165 + 128) × 6960 × 2 = 4,081,440 lamports ≈ 0.00204 SOL  // 不对\n                                                               \n正确：293 × 13920 = 4,078,560 lamports ≈ 0.00204 SOL\n```\n\n### 常见账户大小参考\n\n| 账户类型 | Data Size | 约需 SOL |\n|---------|-----------|---------|\n| 系统账户 | 0 bytes | ~0.00089 SOL |\n| Token Account | 165 bytes | ~0.00204 SOL |\n| Mint Account | 82 bytes | ~0.00144 SOL |\n| 自定义程序账户 | 取决于结构体 | 按公式算 |\n\n---\n\n## 代码计算方式\n\n### 方法1：RPC 调用（最准确）\n```typescript\nconst lamports = await connection.getMinimumBalanceForRentExemption(\n  dataSize  // 字节数\n);\n```\n\n### 方法2：手动计算", "with_skill_answer": "## Solana Rent 机制\n\n### 核心概念\n\nSolana 上的每个账户都需要占用网络存储空间，为了防止无限膨胀，引入了 **rent（租金）** 机制：\n\n- 账户必须维持足够的 SOL 余额，达到 **rent-exempt（免租）** 状态\n- 如果余额不足，账户会被**垃圾回收（删除）**\n\n---\n\n### Rent-Exempt 标准\n\n只要账户余额 ≥ 该账户所需的最低租金，就永久免租，无需持续支付。\n\n**参考标准：**\n| 账户大小 | 所需 SOL |\n|---------|---------|\n| 128 bytes | ≈ 0.00204 SOL |\n| 1 KB | ≈ 0.00714 SOL |\n\n> 数据越大，需要存的 SOL 越多\n\n---\n\n### 计算工具\n\n使用 Solana CLI 直接计算：\n\n```bash\n# 计算指定字节数所需的租金\nsolana rent 128\nsolana rent 1024\n```\n\n---\n\n### 实际影响\n\n```\n创建账户时 → 需预存足够 SOL 覆盖 rent-exempt 门槛\n关闭账户时 → 取回存入的 SOL（退还给用户）\n```\n\n**与以太坊对比：**\n- 以太坊：按 gas 持续付费\n- Solana：**一次性存入 SOL**，关闭账户可取回，更像\"押金\"而非\"费用\"", "skill_found": true, "question_id": "SOL-Q42", "category": "SOL", "skill_id": "solana/program-model", "ground_truth": "每个账户需持有足够 SOL 覆盖其占用空间的租金（lamports/byte/epoch）。Rent-exempt：预存 ≥ 2 年租金，账户永久存在不被删除。计算：`connection.getMinimumBalanceForRentExemption(dataSize)` 返回所需 lamports。账户被关闭时 SOL 返还给 payer。", "question_text": "Solana 的 rent 机制是什么？如何计算账户需要多少 SOL 才能免租？", "provider": "anthropic/claude-sonnet-4-6"}
{"bare_answer": "# 使用 Anchor IDL 创建类型安全的前端客户端\n\n## 核心概念\n\n```\nIDL (Interface Definition Language)\n    ↓\nAnchorProvider + Program<T>\n    ↓\n类型安全的方法调用\n```\n\n## 1. 环境准备\n\n```bash\nnpm install @coral-xyz/anchor @solana/web3.js\nnpm install -D typescript @types/node\n```\n\n## 2. 获取并配置 IDL\n\n```typescript\n// types/idl.ts - 从 target/idl/ 目录获取生成的 IDL\nimport { Idl } from \"@coral-xyz/anchor\";\n\n// 方式一：直接导入 JSON\nimport MyProgramIDL from \"../target/idl/my_program.json\";\n\n// 方式二：从链上获取\nimport { Program } from \"@coral-xyz/anchor\";\nconst idl = await Program.fetchIdl(programId, provider);\n```\n\n## 3. 生成 TypeScript 类型\n\n```bash\n# 使用 anchor 命令生成类型文件\nanchor build\n\n# 类型文件位于 target/types/my_program.ts\n# 包含完整的账户、指令、事件类型定义\n```\n\n## 4. 创建类型安全的 Program 客户端\n\n```typescript\n// client/program.ts\nimport {\n  Program,\n  AnchorProvider,\n  setProvider,\n  web3,\n  BN,\n} from \"@coral-xyz/anchor\";\nimport { Connection, PublicKey, Wallet } from \"@solana/web3.js\";\n\n// 导入生成的类型 (关键：使用 IDL 类型而非 any)\nimport { MyProgram } from \"../target/types/my_program\";\nimport IDL from \"../target/idl/my_program.json\";\n\nconst PROGRAM_ID = new PublicKey(\"Your_Program_ID_Here\");\n\n// ✅ 创建类型安全的 Provider\nexport function createProvider(\n  connection: Connection,\n  wallet: Wallet\n): AnchorProvider {\n  return new AnchorProvider(\n    connection,\n    wallet,\n    AnchorProvider.defaultOptions()\n  );\n}\n\n// ✅ 创建类型安全的 Program 实例\nexport function createProgram(provider: AnchorProvider): Program<MyProgram> {\n  return new Program<MyProgram>(\n    IDL as MyProgram,  // 类型断言确保类型安全\n    PROGRAM_ID,\n    provider\n  );\n}\n```\n\n## 5. 完整的类型安全调用示例\n\n```typescript\n// client/instructions.ts\nimport { Program, BN, web3 } from \"@coral-xyz/anchor\";\nimport { PublicKey, SystemProgram, LAMPORTS_PER_SOL } from \"@solana/web3.js\";\nimport { MyProgram } from \"../target/types/my_program\";\n\n// 假设合约定义如下（Rust）:\n// pub fn initialize(ctx: Context<Initialize>, amount: u64, name: String) -> Result<()>\n//", "with_skill_answer": "# 使用 Anchor IDL 创建类型安全的前端客户端\n\n## 基本设置\n\n```typescript\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport { AnchorProvider, Program, web3 } from \"@coral-xyz/anchor\";\nimport { IDL, MyProgram } from \"./idl/my_program\"; // 引入 IDL 和类型\n\nconst PROGRAM_ID = new PublicKey(\"Your_Program_ID_Here\");\n\n// 1. 创建连接\nconst connection = new Connection(\"https://api.mainnet-beta.solana.com\");\n\n// 2. 创建 Provider（含钱包签名能力）\nconst provider = new AnchorProvider(connection, wallet, {\n  commitment: \"confirmed\",\n});\n\n// 3. 创建类型安全的 Program 客户端\nconst program = new Program<MyProgram>(IDL, PROGRAM_ID, provider);\n//                    ^^^^^^^^^^^ 泛型参数提供完整类型推导\n```\n\n---\n\n## IDL 文件结构示例\n\n```typescript\n// idl/my_program.ts（由 anchor build 自动生成）\nexport type MyProgram = {\n  version: \"0.1.0\";\n  name: \"my_program\";\n  instructions: [\n    {\n      name: \"update\";\n      accounts: [\n        { name: \"myAccount\"; isMut: true; isSigner: false },\n        { name: \"user\"; isMut: true; isSigner: true }\n      ];\n      args: [{ name: \"value\"; type: \"u64\" }];\n    }\n  ];\n};\n\nexport const IDL: MyProgram = { /* ... 具体内容 */ };\n```\n\n---\n\n## 调用指令（类型安全）\n\n```typescript\nimport { BN } from \"@coral-xyz/anchor\";\n\n// ✅ 参数和账户都有类型检查\nconst tx = await program.methods\n  .update(new BN(100))           // 参数类型错误会报编译错误\n  .accounts({\n    myAccount: accountPubkey,    // 缺少账户会有 TS 提示\n    user: wallet.publicKey,\n  })\n  .rpc();\n\nconsole.log(\"Transaction signature:\", tx);\n```\n\n---\n\n## 读取账户数据\n\n```typescript\n// 账户数据也有完整类型推导\nconst accountData = await program.account.myAccount.fetch(accountPubkey);\n//                                 ^^^^^^^^^^ 自动补全账户名称\nconsole.log(accountData.value); // 字段类型安全\n```\n\n---\n\n## 推荐项目结构\n\n```\nsrc/\n├── idl/\n│   └── my_program.ts      # anchor build 生成，勿手动修改\n├── hooks/\n│   └── useProgram.ts      # 封装 program 客户端\n└── utils/\n    └── anchor.ts          # Provider 初始化\n```\n\n---\n\n## 关键要点\n\n| 步骤 | 说明 |\n|------|------|\n| `anchor build`", "skill_found": true, "question_id": "SOL-Q41", "category": "SOL", "skill_id": "protocols/solana-anchor-guide", "ground_truth": "`const program = new Program<MyProgram>(idl, programId, provider)` — IDL 是 Anchor 编译生成的 JSON，描述指令/账户/类型。调用指令：`await program.methods.initialize(arg).accounts({...}).rpc()`。TypeScript 类型从 IDL 自动推断，账户解析用 `program.account.myAccount.fetch(pubkey)`。", "question_text": "如何用 Anchor 生成的 IDL 在前端创建类型安全的 program 客户端？", "provider": "anthropic/claude-sonnet-4-6"}
{"bare_answer": "# Solana Web3.js v2 vs v1 交易构建对比\n\n## 核心设计哲学差异\n\n| 特性 | v1 Transaction | v2 pipe/Builder |\n|------|---------------|-----------------|\n| 设计模式 | 可变对象(Mutable) | 不可变函数式(Immutable) |\n| 类型安全 | 弱类型 | 强类型(TypeScript泛型) |\n| Tree-shaking | ❌ 难以优化 | ✅ 完全支持 |\n| 依赖注入 | 隐式全局 | 显式传入 |\n\n---\n\n## v1 Transaction 方式\n\n```typescript\nimport { Transaction, SystemProgram, sendAndConfirmTransaction } from \"@solana/web3.js\";\n\n// 可变对象，链式修改\nconst transaction = new Transaction();\n\ntransaction.add(\n  SystemProgram.transfer({\n    fromPubkey: sender.publicKey,\n    toPubkey: receiver.publicKey,\n    lamports: 1000000,\n  })\n);\n\ntransaction.recentBlockhash = blockhash;\ntransaction.feePayer = sender.publicKey;\n\n// 签名并发送\nawait sendAndConfirmTransaction(connection, transaction, [sender]);\n```\n\n**问题：**\n- `transaction` 对象状态随时可变\n- 类型系统无法追踪\"是否已设置 blockhash\"\n- 捆绑式导入，bundle 体积大\n\n---\n\n## v2 pipe + 函数式方式\n\n```typescript\nimport { pipe } from \"@solana/functional\";\nimport {\n  createTransactionMessage,\n  setTransactionMessageFeePayer,\n  setTransactionMessageLifetimeUsingBlockhash,\n  appendTransactionMessageInstruction,\n  compileTransaction,\n  signTransaction,\n} from \"@solana/transaction-messages\";\n\n// 每一步返回新对象，类型逐步收窄\nconst transactionMessage = pipe(\n  // 1. 创建基础消息\n  createTransactionMessage({ version: 0 }),\n\n  // 2. 设置付款人\n  (tx) => setTransactionMessageFeePayer(feePayer, tx),\n\n  // 3. 设置生命周期（blockhash）\n  (tx) => setTransactionMessageLifetimeUsingBlockhash(\n    { blockhash, lastValidBlockHeight },\n    tx\n  ),\n\n  // 4. 添加指令\n  (tx) => appendTransactionMessageInstruction(\n    SystemProgram.transfer({ ... }),\n    tx\n  )\n);\n\n// 编译 + 签名是独立步骤\nconst compiledTx = compileTransaction(transactionMessage);\nconst signedTx = await signTransaction([keyPair], compiledTx);\n```\n\n---\n\n## 类型系统的关键进化\n\n```typescript\n// v2 类型会随操作逐步收窄！\n\n// 初始类型\ntype Step1 = TransactionMessage;\n\n// 添加 feePayer 后\ntype Step2 = TransactionMessage & I", "with_skill_answer": "## @solana/web3.js v2 vs v1 Transaction 对比\n\n### v1 的 Transaction 对象（命令式/可变）\n\n```typescript\n// v1 - 可变对象，命令式操作\nconst transaction = new Transaction();\ntransaction.add(instruction1);\ntransaction.add(instruction2);\ntransaction.recentBlockhash = blockhash;\ntransaction.feePayer = publicKey;\n\nconst signed = await wallet.signTransaction(transaction);\nawait connection.sendRawTransaction(signed.serialize());\n```\n\n**问题：**\n- 对象可变（mutable），难以追踪状态\n- 隐式依赖，步骤顺序不明确\n- Tree-shaking 困难（class-based）\n\n---\n\n### v2 的 pipe + 函数式构建\n\n```typescript\n// v2 - 不可变管道，函数式组合\nimport { pipe } from \"@solana/functional\";\nimport {\n  createTransactionMessage,\n  setTransactionMessageFeePayer,\n  setTransactionMessageLifetimeUsingBlockhash,\n  appendTransactionMessageInstruction,\n  compileTransaction,\n  signTransaction,\n} from \"@solana/web3.js\";\n\nconst transaction = pipe(\n  createTransactionMessage({ version: 0 }),                          // 创建初始消息\n  (tx) => setTransactionMessageFeePayer(feePayer, tx),               // 设置付款方\n  (tx) => setTransactionMessageLifetimeUsingBlockhash(blockhash, tx),// 设置 blockhash\n  (tx) => appendTransactionMessageInstruction(instruction1, tx),     // 添加指令\n  (tx) => appendTransactionMessageInstruction(instruction2, tx),     // 添加指令\n);\n\nconst signedTx = await signTransaction([signerKeyPair], transaction);\n```\n\n---\n\n### 核心差异对比\n\n| 特性 | v1 Transaction | v2 pipe |\n|------|---------------|---------|\n| **可变性** | Mutable（可变） | Immutable（不可变） |\n| **编程范式** | 命令式 OOP | 函数式组合 |\n| **类型安全** | 较弱 | 强类型（TypeScript 类型状态） |\n| **Tree-shaking** | ❌ class 难以优化 | ✅ 纯函数，按需引入 |\n| **Bundle 体积** | 较大 | 显著减小 |\n| **步骤可见性** | 隐式 | 显式管道，每步清晰 |\n\n---\n\n### v2 类型状态（Type State）的优势\n\nv2 利用 TypeScript 类型系统防止错误：\n\n```typescript\n// 未设置 feePayer 时，类型不满足签名条件\n// 编译阶段就报错，而非运行时\nconst tx = createTransactionMessage({ version: 0 });\n// tx 类型: TransactionMessage（不完整）\n\nconst txWithFee = setTransactionMessageFeePayer(feePayer,", "skill_found": true, "question_id": "SOL-Q44", "category": "SOL", "skill_id": "solana/program-model", "ground_truth": "v2 采用函数式 pipe 风格：`pipe(createTransaction({version: 0}), tx => appendTransactionMessageInstructions([ix1, ix2], tx), tx => setTransactionMessageFeePayer(payer, tx))`。不可变对象设计，每步返回新对象。比 v1 的命令式 `transaction.add()` 更类型安全，tree-shakeable，包体积更小。", "question_text": "@solana/web3.js v2 的 pipe/transactionBuilder 与 v1 的 Transaction 对象有何不同？", "provider": "anthropic/claude-sonnet-4-6"}
{"bare_answer": "# Anchor 程序自定义错误定义与前端解析\n\n## 一、程序端定义自定义错误\n\n### 1. 基本错误定义\n\n```rust\nuse anchor_lang::prelude::*;\n\n#[program]\npub mod my_program {\n    use super::*;\n\n    pub fn transfer(ctx: Context<Transfer>, amount: u64) -> Result<()> {\n        // 使用 require! 宏抛出错误\n        require!(amount > 0, MyError::InvalidAmount);\n        require!(amount <= 1000, MyError::AmountTooLarge);\n        \n        // 使用 require_keys_eq! 检查公钥\n        require_keys_eq!(\n            ctx.accounts.authority.key(),\n            ctx.accounts.vault.authority,\n            MyError::Unauthorized\n        );\n\n        // 条件返回错误\n        if ctx.accounts.vault.is_frozen {\n            return Err(MyError::VaultFrozen.into());\n        }\n\n        Ok(())\n    }\n}\n\n// 定义错误枚举\n#[error_code]\npub enum MyError {\n    #[msg(\"金额必须大于0\")]\n    InvalidAmount,\n    \n    #[msg(\"金额不能超过1000\")]\n    AmountTooLarge,\n    \n    #[msg(\"没有操作权限\")]\n    Unauthorized,\n    \n    #[msg(\"金库已被冻结\")]\n    VaultFrozen,\n    \n    // 支持动态消息（需要自定义 Display）\n    #[msg(\"余额不足，需要 {} 但只有 {}\")]\n    InsufficientFunds,\n}\n```\n\n### 2. 错误码范围规则\n\n```rust\n// Anchor 错误码分配：\n// 0-99:       Anchor 内置错误 (AccountNotInitialized 等)\n// 6000+:      自定义错误（默认从 6000 开始）\n\n#[error_code]\npub enum MyError {\n    // 自动分配：6000\n    InvalidAmount,\n    // 自动分配：6001\n    AmountTooLarge,\n    // 手动指定错误码\n    #[msg(\"自定义错误\")]\n    CustomError = 6100,\n}\n```\n\n### 3. 复杂错误处理模式\n\n```rust\n#[program]\npub mod my_program {\n    pub fn complex_operation(ctx: Context<ComplexOp>) -> Result<()> {\n        // 链式验证\n        validate_account(&ctx.accounts.user)?;\n        validate_amount(ctx.accounts.vault.balance, 100)?;\n        \n        Ok(())\n    }\n}\n\n// 抽取验证函数\nfn validate_account(account: &Account<UserAccount>) -> Result<()> {\n    require!(account.is_active, MyError::AccountInactive);\n    require!(!account.is_banned, MyError::AccountBanned);\n    Ok(())\n}\n\nfn validate_amount(balance: u64, required: u64) -> Result<()> {\n    if balance < required {", "with_skill_answer": "# Anchor 自定义错误定义与前端解析\n\n## 一、程序端定义自定义错误\n\n### 1. 定义错误枚举\n\n```rust\nuse anchor_lang::prelude::*;\n\n#[program]\npub mod my_program {\n    use super::*;\n    \n    pub fn transfer(ctx: Context<Transfer>, amount: u64) -> Result<()> {\n        // 使用 require! 宏抛出错误\n        require!(amount > 0, MyError::InvalidAmount);\n        require!(\n            ctx.accounts.user.balance >= amount,\n            MyError::InsufficientFunds\n        );\n        require!(\n            !ctx.accounts.user.is_frozen,\n            MyError::AccountFrozen\n        );\n        \n        Ok(())\n    }\n}\n\n// 定义错误枚举\n#[error_code]\npub enum MyError {\n    #[msg(\"转账金额必须大于零\")]\n    InvalidAmount,\n    \n    #[msg(\"余额不足，无法完成转账\")]\n    InsufficientFunds,\n    \n    #[msg(\"账户已被冻结\")]\n    AccountFrozen,\n    \n    #[msg(\"自定义错误: 期望 {expected}，实际 {actual}\")]\n    CustomError {\n        expected: u64,\n        actual: u64,\n    },\n}\n```\n\n### 2. 多种抛出错误方式\n\n```rust\npub fn example(ctx: Context<Example>, value: u64) -> Result<()> {\n    // 方式1: require! 宏（推荐）\n    require!(value > 0, MyError::InvalidAmount);\n    \n    // 方式2: require_eq! / require_neq! / require_gt!\n    require_gt!(value, 0, MyError::InvalidAmount);\n    require_eq!(value, 100, MyError::InvalidAmount);\n    \n    // 方式3: 手动返回错误\n    if value == 0 {\n        return Err(MyError::InvalidAmount.into());\n    }\n    \n    // 方式4: err! 宏\n    if value == 0 {\n        return err!(MyError::InvalidAmount);\n    }\n    \n    Ok(())\n}\n```\n\n### 3. 错误码范围说明\n\n```rust\n// Anchor 错误码规则：\n// 0-99:      系统预留\n// 100-299:   Anchor 框架错误\n// 6000+:     用户自定义错误（自动从 6000 开始分配）\n\n#[error_code]\npub enum MyError {\n    InvalidAmount,      // 错误码: 6000\n    InsufficientFunds,  // 错误码: 6001\n    AccountFrozen,      // 错误码: 6002\n}\n```\n\n---\n\n## 二、前端解析错误\n\n### 1. 基础错误捕获\n\n```typescript\nimport { AnchorError, Program } from \"@coral-xyz/anchor\";\n\nasync function transferTokens