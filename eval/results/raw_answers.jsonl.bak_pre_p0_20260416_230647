{"bare_answer": "# 在本地测试 fhEVM 合约\n\n## 方案概览\n\n```\n本地测试方案\n├── 方案1: Mock 模式（推荐开发阶段）\n├── 方案2: fhEVM 本地节点（完整测试）\n└── 方案3: Hardhat + fhEVM-mock 库\n```\n\n---\n\n## 方案1：Mock 模式（最简单）\n\n### 安装依赖\n\n```bash\nmkdir my-fhevm-project && cd my-fhevm-project\nnpm init -y\nnpm install --save-dev hardhat @nomicfoundation/hardhat-toolbox\nnpm install fhevm\n```\n\n### 配置 hardhat.config.ts\n\n```typescript\nimport { HardhatUserConfig } from \"hardhat/config\";\nimport \"@nomicfoundation/hardhat-toolbox\";\n\nconst config: HardhatUserConfig = {\n  solidity: {\n    version: \"0.8.24\",\n    settings: {\n      optimizer: { enabled: true, runs: 200 },\n    },\n  },\n  networks: {\n    hardhat: {\n      // Mock 模式：本地无需真实 FHE 运算\n    },\n    localhost: {\n      url: \"http://127.0.0.1:8545\",\n    },\n  },\n};\n\nexport default config;\n```\n\n### 编写 Mock 合约\n\n```solidity\n// SPDX-License-Identifier: MIT\npragma solidity ^0.8.24;\n\nimport \"fhevm/lib/TFHE.sol\";\nimport \"fhevm/config/ZamaFHEVMConfig.sol\";\n\ncontract EncryptedCounter is SepoliaZamaFHEVMConfig {\n    euint32 private counter;\n    \n    constructor() {\n        // 初始化加密计数器为 0\n        counter = TFHE.asEuint32(0);\n        TFHE.allowThis(counter);\n    }\n    \n    function increment(einput encryptedAmount, bytes calldata inputProof) external {\n        euint32 amount = TFHE.asEuint32(encryptedAmount, inputProof);\n        counter = TFHE.add(counter, amount);\n        TFHE.allowThis(counter);\n        TFHE.allow(counter, msg.sender);\n    }\n    \n    function getCounter(address user) external view returns (euint32) {\n        return counter;\n    }\n}\n```\n\n### 编写测试（Mock 模式）\n\n```typescript\n// test/EncryptedCounter.test.ts\nimport { expect } from \"chai\";\nimport { ethers } from \"hardhat\";\nimport { createInstances } from \"../utils/instance\";  // fhEVM 实例工具\n\ndescribe(\"EncryptedCounter - Mock Mode\", function () {\n  let counter: any;\n  let signers: any;\n  let instances: any;\n\n  before(async function () {\n    signers = await ethers.getSigners();\n  });\n\n  beforeEach(async function () {\n    const CounterFactory = await ethers.getContractFactory(\"EncryptedCounter\");", "with_skill_answer": "# 本地测试 fhEVM 合约\n\n## 核心原理\n\n`@fhevm/hardhat-plugin` 内置了本地模拟环境，**无需连接 Sepolia** 即可在 Hardhat 网络上运行加密计算测试。\n\n---\n\n## 配置步骤\n\n### 1. 安装依赖\n\n```bash\nnpm install --save-dev hardhat @fhevm/hardhat-plugin\n```\n\n### 2. 配置 `hardhat.config.ts`\n\n```typescript\nimport \"@fhevm/hardhat-plugin\";\nimport { HardhatUserConfig } from \"hardhat/config\";\n\nconst config: HardhatUserConfig = {\n  solidity: \"0.8.27\",\n  // ✅ 不配置任何外部网络，默认使用本地 hardhat network\n  networks: {\n    hardhat: {\n      // 本地网络，fhevm 插件自动接管加密操作\n    },\n  },\n};\n\nexport default config;\n```\n\n### 3. 编写本地测试\n\n```typescript\nimport { ethers, fhevm } from \"hardhat\";\nimport { FhevmType } from \"@fhevm/hardhat-plugin\";\nimport { expect } from \"chai\";\n\ndescribe(\"本地 fhEVM 测试\", function () {\n  it(\"加密输入 → 合约运算 → 解密验证\", async function () {\n    const [alice] = await ethers.getSigners();\n\n    // 1️⃣ 部署合约\n    const contract = await ethers.deployContract(\"FHECounter\");\n    const contractAddress = await contract.getAddress();\n\n    // 2️⃣ 创建加密输入（本地模拟，无需链上交互）\n    const enc = await fhevm\n      .createEncryptedInput(contractAddress, alice.address)\n      .add32(5)\n      .encrypt();\n\n    // 3️⃣ 发送交易\n    await contract\n      .connect(alice)\n      .increment(enc.handles[0], enc.inputProof);\n\n    // 4️⃣ 用户解密（本地模拟 KMS）\n    const handle = await contract.getCount();\n    const value = await fhevm.userDecryptEuint(\n      FhevmType.euint32,\n      handle,\n      contractAddress,\n      alice\n    );\n\n    expect(value).to.equal(5n);\n  });\n\n  it(\"公开解密（publicDecrypt）\", async function () {\n    const contract = await ethers.deployContract(\"FHEAuction\");\n    const contractAddress = await contract.getAddress();\n\n    // 触发合约内部加密操作...\n    const encryptedHandle = await contract.getHighestBid