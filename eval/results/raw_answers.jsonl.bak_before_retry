ion,\n  PublicKey,\n  Transaction,\n  SystemProgram,\n  ComputeBudgetProgram,\n  sendAndConfirmTransaction,\n} from '@solana/web3.js';\n\nconst connection = new Connection('https://api.mainnet-beta.solana.com');\n\nasync function sendTransactionWithCustomComputeBudget() {\n  const transaction = new Transaction();\n\n  // 设置自定义 compute budget\n  const computeBudgetInstruction = ComputeBudgetProgram.setComputeUnitLimit({\n    units: 500000, // 设置为 500,000 compute units\n  });\n\n  transaction.add(computeBudgetInstruction);\n  transaction.add(\n    SystemProgram.transfer({\n      fromPubkey: senderPublicKey,\n      toPubkey: recipientPublicKey,\n      lamports: amount,\n    })\n  );\n\n  const signature = await sendAndConfirmTransaction(connection, transaction, {\n    signers: [senderKeypair],\n  });\n\n  console.log('Transaction signature', signature);\n}\n\nsendTransactionWithCustomComputeBudget();\n```\n\n在这个示例中，我们首先创建了一个交易，然后使用 `ComputeBudgetProgram.setComputeUnitLimit` 方法来设置自定义的 compute units 限制。接着，我们将计算预算指令和其他交易指令添加到交易中，并发送交易。", "skill_found": true, "question_id": "SOL-Q39", "category": "SOL", "skill_id": "solana/web3js-v2", "ground_truth": "默认限制：每条指令 200,000 CU，单交易最多 1,400,000 CU。自定义：添加 `ComputeBudgetProgram.setComputeUnitLimit({ units: 300000 })` 指令提高上限；添加 `setComputeUnitPrice({ microLamports: 1000 })` 设置优先费。两条指令加在交易最前面。", "question_text": "Solana 交易的 compute units 限制是多少？如何设置自定义 compute budget？", "provider": "openai/gpt-4o-mini"}
